# .env là tùy chọn.
# Bạn có thể bỏ qua file này hoàn toàn nếu truyền options trực tiếp trong code:
# createClient({ cookie, defaults: { speakerId, modelId, audioType } })

# =========================
# BẮT BUỘC KHI GỌI API THẬT
# =========================

# Cookie đăng nhập lấy từ browser DevTools > Network > Request Headers > Cookie.
# Chỉ cần COOKIE là đủ trong hầu hết trường hợp vì csrftoken/sessionid sẽ được tách tự động.
# Không commit cookie thật lên GitHub/npm.
COOKIE=django_language=vi; csrftoken=your_csrftoken_here; sessionid=your_sessionid_here

# Nếu không muốn dùng nguyên COOKIE, có thể dùng riêng 2 biến này.
# Khi đó thư viện sẽ tự build Cookie: csrftoken=...; sessionid=...
# CSRFTOKEN=your_csrftoken_here
# SESSIONID=your_sessionid_here

# =========================
# TÙY CHỌN CÓ THỂ ĐỔI
# =========================

# Base URL của EverAI web app. Thường không cần đổi.
BASE_URL=https://www.everai.vn/

# Nội dung mặc định cho CLI `npm run tts` nếu không truyền --text.
TTS_TEXT=Xin chào, đây là đoạn thử nghiệm tạo giọng nói bằng EverAI.

# Voice mặc định. Đây là option quan trọng nhất sau COOKIE.
# Có thể đổi bằng voice id lấy từ giao diện EverAI.
SPEAKER_ID=voice-e829405f-8101-414e

# Model TTS. Có thể đổi nếu EverAI hỗ trợ model khác cho tài khoản của bạn.
MODEL_ID=everai-v1.5

# Style là tùy chọn. Mặc định không cần.
# Chỉ bật nếu voice/model bạn chọn cần style riêng.
# STYLE_ID=style-optional

# Định dạng audio mong muốn. Thường dùng mp3 hoặc wav.
# Một số tài khoản/model có thể không hỗ trợ wav.
AUDIO_TYPE=mp3

# Tham số giọng đọc theo UI EverAI.
# SPEED: tốc độ đọc. 1.0 là bình thường, tối đa 1.5.
SPEED=1.0
# PITCH: cao độ giọng. 1.0 là bình thường, tối đa 1.5.
PITCH=1.0
# VOLUME: âm lượng. 100 là bình thường, tối đa 150.
VOLUME=100
# ENHANCE_VOICE: bật/tắt tăng cường giọng nếu tài khoản/model hỗ trợ.
ENHANCE_VOICE=false

# Cấu hình polling chờ link audio sau khi tạo request.
ATTEMPTS=20
INTERVAL_MS=3000

# Mức log: silent, error, warn, info, debug.
# Dùng debug khi cần xem chi tiết request/polling, nhưng log không in cookie/csrf/session.
LOG_LEVEL=info
